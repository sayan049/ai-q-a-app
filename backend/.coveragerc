[run]
source = app
branch = True

[report]
exclude_lines =
    pragma: no cover
    if __name__ == .__main__.:
    raise NotImplementedError
    pass
    \.\.\.

omit =
    app/main.py
    app/api/auth.py
    app/api/files.py
    app/api/chat.py
    app/api/summary.py
    app/services/cache_service.py
    app/services/summary_service.py
